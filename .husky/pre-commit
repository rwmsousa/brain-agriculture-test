#!/usr/bin/env sh

# Run lint-staged and TypeScript checks in both projects
echo "Running pre-commit checks..."

cd backend && npx lint-staged && npx tsc --noEmit
BACKEND_EXIT=$?
cd ..

cd frontend && npx lint-staged && npx tsc --noEmit
FRONTEND_EXIT=$?
cd ..

if [ $BACKEND_EXIT -ne 0 ] || [ $FRONTEND_EXIT -ne 0 ]; then
  echo "Pre-commit checks failed."
  exit 1
fi

echo "Pre-commit checks passed."
